# ── Supabase ──
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<anon-key>
NUXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=<anon-key>

# ── App ──
NUXT_PUBLIC_APP_URL=https://app.viewora.software

# ── PostHog ──
NUXT_PUBLIC_POSTHOG_KEY=
NUXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry (client-side) ──
# Public DSN for Sentry (browser). Set this to enable client-side error reporting.
NUXT_PUBLIC_SENTRY_DSN=
# Leave empty to use the built-in Nitro proxy (/api/*).
# Set to the Fastify backend URL (e.g. https://api.viewora.software) when deploying separately.
NUXT_PUBLIC_API_BASE_URL=
# Server-only API base URL used by Nitro proxy route /api/**.
# Prefer setting this in production so backend URL is not exposed to clients.
NUXT_API_BASE_URL=
